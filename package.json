{
  "name": "use",
  "version": "1.0.0",
  "description": "",
  "main": "",
  "scripts": {
    "mac:brew": "bash ./scripts/mac/brew-install.sh",
    "mac:backup": "brew bundle dump --no-vscode --no-npm --force --file=./configs/mac/Brewfile",
    "mac:setup": "brew bundle install --file=./configs/mac/Brewfile",
    "mac:init": "bash ./scripts/mac/init.sh",
    "mac:sync": "bash ./scripts/mac/config-sync.sh",
    "win:scoop": "node ./scripts/windows/dispatch.mjs scoop",
    "win:backup": "scoop export > ./configs/windows/scoop_backup.json",
    "win:setup": "scoop import ./configs/windows/scoop_backup.json",
    "win:init": "node ./scripts/windows/dispatch.mjs init",
    "win:sync": "node ./scripts/windows/dispatch.mjs sync",
    "win:zsh": "node ./scripts/windows/dispatch.mjs zsh",
    "win:git-extras": "node ./scripts/windows/dispatch.mjs git-extras",
    "win:clink": "node ./scripts/windows/dispatch.mjs clink",
    "common:sync": "bash ./scripts/common/config-sync.sh",
    "common:setup": "bash ./scripts/common/git-setup.sh"
  },
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.4"
}

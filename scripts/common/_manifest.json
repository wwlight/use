{
  "directories": [
    "~/.zsh/plugins",
    "~/.zsh/cache",
    "~/.zsh/history",
    "~/.zsh/functions",
    "~/.config/starship"
  ],
  "git": {
    "credentialHelper": "store",
    "defaultBranch": "main",
    "ignorecase": false,
    "safeDirectory": "*"
  },
  "sync": {
    "toRepo": [
      { "local": "~/.zsh/.zshrc_core", "repo": "configs/common/.zshrc_core" },
      { "local": "~/.zsh/functions/_eza", "repo": "configs/common/_eza" },
      { "local": "~/.zsh/functions/aliases.zsh", "repo": "configs/common/aliases.zsh" },
      { "local": "~/.config/starship/starship.toml", "repo": "configs/common/starship.toml" },
      { "local": "~/.config/opencode/opencode.jsonc", "repo": "configs/common/opencode.jsonc", "backup": true, "lite": false }
    ]
  },
  "zshPlugins": [
    { "name": "zsh-autocomplete", "repo": "https://github.com/marlonrichert/zsh-autocomplete.git" },
    { "name": "zsh-autosuggestions", "repo": "https://github.com/zsh-users/zsh-autosuggestions.git" },
    { "name": "zsh-syntax-highlighting", "repo": "https://github.com/zsh-users/zsh-syntax-highlighting.git" },
    { "name": "zsh-completions", "repo": "https://github.com/zsh-users/zsh-completions.git" }
  ]
}

{
  "clinkPlugins": [
    { "name": "clink-completions", "repo": "https://github.com/vladimir-kotikov/clink-completions" },
    { "name": "clink-gizmos", "repo": "https://github.com/chrisant996/clink-gizmos" }
  ],
  "directories": [
    "D:/SoftwareApps"
  ],
  "gitExtras": {
    "repo": "https://github.com/tj/git-extras.git"
  },
  "githubHostsUrl": "https://raw.hellogithub.com/hosts",
  "scoopBackup": "configs/windows/scoop_backup.json",
  "scoopDir": "D:\\SoftwareApps\\Scoop",
  "softwareAppsDir": "D:/SoftwareApps",
  "sync": {
    "toRepo": [
      { "local": "~/.zshenv", "repo": "configs/common/.zshenv" },
      { "local": "~/.zsh/.zshrc", "repo": "configs/windows/.zshrc", "backup": true },
      { "local": "~/.bashrc", "repo": "configs/windows/.bashrc" },
      { "local": "~/.zsh/functions/utils.zsh", "repo": "configs/windows/utils.zsh" },
      { "local": "~/.zsh/functions/aliases.win.zsh", "repo": "configs/windows/aliases.zsh" },
      { "local": "~/.zsh/functions/scoop_services.zsh", "repo": "configs/windows/scoop_services.zsh" },
      { "local": "D:/SoftwareApps/Scoop/config/services-manifest.json", "repo": "configs/windows/services-manifest.json" },
      { "local": "~/Documents/WindowsPowerShell/Microsoft.PowerShell_profile.ps1", "repo": "configs/windows/pwsh5_profile.ps1", "backup": true },
      { "local": "~/Documents/PowerShell/Microsoft.PowerShell_profile.ps1", "repo": "configs/windows/pwsh7_profile.ps1", "backup": true }
    ]
  },
  "zshInstall": {
    "archiveName": "zsh-5.9-4-x86_64.pkg.tar.zst",
    "cpErrorLog": "cp_error.log",
    "downloadUrl": "https://mirror.msys2.org/msys/x86_64/zsh-5.9-4-x86_64.pkg.tar.zst",
    "tempExtractDir": "zsh-temp-extract",
    "workDir": "~/Desktop"
  }
}
